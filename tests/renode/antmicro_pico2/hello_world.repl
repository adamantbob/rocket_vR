sysbus:
    init:
        Tag <0xd0000000 0x14000> "sio"
        Tag <0x50000000 0x10000> "dma"
        Tag <0x50110000 0x10000> "usbd"
        Tag <0x40010000 0x1000> "clocks"
        Tag <0x40020000 0x1000> "reset"
        Tag <0x40028000 0x1000> "gpio0_map"
        Tag <0x40048000 0x1000> "clocks"
        Tag <0x40050000 0x1000> "clocks"
        Tag <0x40058000 0x1000> "clocks"
        Tag <0x40078000 0x1000> "uart1"
        Tag <0x40080000 0x1000> "spi0"
        Tag <0x40088000 0x1000> "spi1"
        Tag <0x40090000 0x1000> "i2c0"
        Tag <0x40098000 0x1000> "i2c1"
        Tag <0x400a0000 0x1000> "adc"
        Tag <0x400a8000 0x1000> "pwm"
        Tag <0x400b0000 0x1000> "timer0"
        Tag <0x400b8000 0x1000> "timer1"
        Tag <0x400d8000 0x1000> "wdt0"
        Tag <0x400e8000 0x1000> "clocks"
        Tag <0x400f0000 0x1000> "rng"
        Tag <0x50200000 0x1000> "pio0"
        Tag <0x50300000 0x1000> "pio1"
        Tag <0x50400000 0x1000> "pio2"
        Tag <0x400f8000 0x200> "sha256"
        Tag <0x40100000 0x200> "vreg"
        Tag <0x400d0000 0x54> "qmi"
        Tag <0xe000e010 0x10> "systick"

flash0: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x400000

sram0: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x82000

// autogenerated

nvic0: IRQControllers.NVIC @ {
    sysbus new Bus.BusPointRegistration { address: 0xe000e000; cpu: cpu0 }
}
    -> cpu0@0
    systickFrequency: 150000000

cpu0: CPU.CortexM @ sysbus
    cpuType: "cortex-m33"
    nvic: nvic0

cpu1: CPU.CortexM @ sysbus
    cpuType: "cortex-m33"
    nvic: nvic1

nvic1: IRQControllers.NVIC @ {
    sysbus new Bus.BusPointRegistration { address: 0xe000e000; cpu: cpu1 }
}

uart0: UART.PL011 @ sysbus 0x40070000
    ->nvic0@33

// cortex-m overlay

dwt: Miscellaneous.DWT @ sysbus 0xE0001000
    frequency: 72000000
